# Kripto-Bot — Ortam Değişkenleri Örneği
# Kurulum: cp .env.example .env
# Docker Compose ile çalıştırırken backend 8002, frontend 3002 portunda yayında.

# === DEMO MODE (zorunlu) ===
DEMO_MODE_ONLY=true

# === Database (Docker: postgres servisi; yerel: 127.0.0.1:5433) ===
DATABASE_URL=postgresql+asyncpg://polybot:polybot_dev@postgres:5432/polybot
DATABASE_URL_SYNC=postgresql://polybot:polybot_dev@postgres:5432/polybot
POSTGRES_USER=polybot
POSTGRES_PASSWORD=polybot_dev
POSTGRES_DB=polybot

# === Redis (Docker: redis servisi; yerel: 127.0.0.1:6380) ===
REDIS_URL=redis://redis:6379/0

# === Polymarket API (public, kimlik gerekmez) ===
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# === Polling ===
POLL_INTERVAL_SECONDS=10
SNAPSHOT_INTERVAL_SECONDS=5
WALLET_POLL_INTERVAL_SECONDS=10

# === Backend ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Araştırma modu: kill switch'i kapatır, direct_copy/high_conviction aktif kalır (veri toplama)
STRATEGY_RESEARCH_MODE=true

# === Exit engine — execution layer tuning (stale_data / stop_loss) ===
# STALE_SNAPSHOT_HOURS=4
# STALE_SOFT_GUARD=false
# STALE_EXIT_DISABLED=false
# STOP_LOSS_PCT=0.10
# STALE_MARKET_BLACKLIST=   # comma-separated market UUIDs from /api/analytics/stale-data-analytics suggested_blacklist
# === Wallet quality (direct_copy gate + blacklist) ===
# DIRECT_COPY_MIN_COMPOSITE=0.35   # high_conviction 0.5'tan daha gevşek; Phase 1 sadece composite
# DIRECT_COPY_MIN_COPYABILITY=0    # Phase 1'de kapalı; tek değişken deneyi
# WALLET_BLACKLIST=                # comma-separated wallet UUIDs from /api/wallets/worst-by-copy-pnl suggested_blacklist
# === Runner: new-trade detection window (default 15min; was 2min — too strict, caused no new trades) ===
# NEW_TRADE_WINDOW_MINUTES=15
# === Wallet influence A/B test (Bayesian input dampening) ===
# Default: 0.6 / 0.5. Test branch: 0.3 / 0.25 for healthier distribution, less over-concentration
# WALLET_IMBALANCE_FACTOR=0.6
# WALLET_REPRICING_FACTOR=0.5
# === Calibration / tradable-edge gates (Phase 1-3) ===
# CALIBRATION_REFRESH_SEC=300
# CALIBRATION_LOOKBACK_DAYS=14
# CALIBRATION_MIN_SAMPLES=120
# CALIBRATION_MIN_SAMPLES_ISOTONIC=300
# MIN_CALIBRATED_CONFIDENCE=0.05
# BASE_FILL_PROBABILITY=0.70
# Phase rollout guide:
# 2A (12h): STALE_SOFT_GUARD=true,  STALE_EXIT_DISABLED=false, STALE_MARKET_BLACKLIST=
# 2B (12h): STALE_SOFT_GUARD=true,  STALE_EXIT_DISABLED=true,  STALE_MARKET_BLACKLIST=
# 2C       STALE_SOFT_GUARD=true,  STALE_EXIT_DISABLED=false, STALE_MARKET_BLACKLIST=<top5-10>
# Exit stabilization (first 72h): STOP_LOSS_PCT=0.10 sabit (sweep yok)
# Post-patch validation: ISO datetime (örn. 2026-03-16T22:00:00Z) — restart sonrası bu değeri set et
# VALIDATION_CUTOFF_AT=2026-03-16T22:00:00Z
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Frontend (tarayıcı backend'e bu adreslerden istek atar; Docker'da backend 8002) ===
NEXT_PUBLIC_API_URL=http://localhost:8002
NEXT_PUBLIC_WS_URL=ws://localhost:8002/ws/live
